---
import { Card, CardHeader, CardContent, CardFooter } from "@/components/ui/card";

interface Props {
  title: string;
  description?: string;
  image?: string;
  price?: string;
  ctaLabel?: string;
  footer?: astro.ComponentProps<any>;
}

const { title, description, image, price, ctaLabel = "View Details", footer } = Astro.props;
---

<Card>
  <CardHeader>
    <span class="block">{title}</span>
  </CardHeader>
  <CardContent>
  </CardContent>
  <CardFooter>
  </CardFooter>
</Card>

{"$schema": "https://ui.shadcn.com/schema/registry-item.json", "name": "team-2", "title": "Team Profile 2", "description": "A clean and modern team profile", "dependencies": [], "registryDependencies": ["button", "card"], "files": [{"path": "resources/js/components/blocks/marketing/teams/Team2.tsx", "content": "import { Card, CardContent } from '@/components/ui/card'\nimport { Button } from '@/components/ui/button'\n\nconst agents = [\n  {\n    id: 1,\n    name: 'Nathan James',\n    phone: '1-234-456-7893',\n    email: 'nathan@realhomes.io',\n    image: 'https://notion-avatars.netlify.app/api/avatar?preset=male-1',\n    properties: 3,\n  },\n  {\n    id: 2,\n    name: 'Melissa William',\n    phone: '1-234-456-7892',\n    email: 'melissa@realhomes.io',\n    image: 'https://notion-avatars.netlify.app/api/avatar?preset=female-1',\n    properties: 5,\n  },\n  {\n    id: 3,\n    name: 'Alice Brian',\n    phone: '1-234-456-7891',\n    email: 'alice@realhomes.io',\n    image: 'https://notion-avatars.netlify.app/api/avatar?preset=female-2',\n    properties: 5,\n  },\n  {\n    id: 4,\n    name: 'John David',\n    phone: '1-234-456-7890',\n    email: 'john@realhomes.io',\n    image: 'https://notion-avatars.netlify.app/api/avatar?preset=male-2',\n    properties: 6,\n  },\n]\n\nconst Team2 = () => {\n  return (\n    <section className='w-full py-16 md:py-24'>\n      <div className='mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8'>\n        {/* Section Header */}\n        <header className='mb-12 text-center'>\n          <p className='text-muted-foreground text-sm font-medium tracking-wider uppercase'>Check Out</p>\n          <h2 className='text-foreground mt-1 mb-3 text-3xl font-bold text-balance md:text-4xl'>Agents Grid</h2>\n          <p className='text-muted-foreground'>RealHomes Elementor widgets for Agents</p>\n        </header>\n\n        {/* Agents Grid */}\n        <div className='grid grid-cols-1 gap-8 sm:grid-cols-2 md:gap-6 lg:grid-cols-4'>\n          {agents.map(agent => (\n            <div key={agent.id} className='group relative pt-2 transition-all duration-300 hover:-translate-y-1'>\n              <Card className='bg-card relative mt-8 overflow-visible py-0 pt-16 text-center transition-all duration-300 hover:shadow-lg'>\n                {/* Floating Image */}\n                <div className='absolute inset-x-0 -top-8 flex justify-center'>\n                  <div className='border-border bg-background rounded-full border p-1.5 shadow-md transition-transform duration-300 group-hover:-translate-y-1'>\n                    <div className='border-background bg-accent size-24 overflow-hidden rounded-full border-2'>\n                      <img\n                        src={agent.image}\n                        alt={`${agent.name}, Real Estate Agent`}\n                        width={96}\n                        height={96}\n                        className='size-full'\n                        loading='lazy'\n                      />\n                    </div>\n                  </div>\n                </div>\n\n                <CardContent className='flex flex-col justify-between p-6'>\n                  <h3 className='text-foreground mb-3 text-xl font-semibold transition-colors'>{agent.name}</h3>\n\n                  <Button\n                    variant='link'\n                    size='sm'\n                    className=\"h-8 px-3 text-xs text-muted-foreground hover:text-foreground h-auto cursor-pointer p-0 font-medium hover:no-underline\"\n                    asChild\n                  >\n                    <a href={`tel:${agent.phone}`}>{agent.phone}</a>\n                  </Button>\n\n                  <Button\n                    variant='link'\n                    size='sm'\n                    className=\"h-8 px-3 text-xs text-muted-foreground hover:text-foreground mb-6 h-auto cursor-pointer p-0 text-sm hover:no-underline\"\n                    asChild\n                  >\n                    <a href={`mailto:${agent.email}`}>{agent.email}</a>\n                  </Button>\n\n                  <div className='border-border border-t pt-4 text-center'>\n                    <span className='text-foreground mb-1 block text-3xl font-bold'>{agent.properties}</span>\n                    <span className='text-muted-foreground text-sm'>Listed Properties</span>\n                  </div>\n                </CardContent>\n              </Card>\n            </div>\n          ))}\n        </div>\n      </div>\n    </section>\n  )\n}\n\nexport default Team2\n", "type": "registry:block", "target": "src/components/team-2.tsx"}], "type": "registry:block"}
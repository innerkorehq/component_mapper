{"$schema": "https://ui.shadcn.com/schema/registry-item.json", "name": "cta-02", "description": "A simple cta section.", "dependencies": ["@aliimam/logos"], "registryDependencies": ["button"], "files": [{"path": "blocks/cta/cta-02/cta.tsx", "content": "\"use client\"\n\nimport { Award, Cat, ShieldCheck, Star, StarHalf } from \"@aliimam/icons\"\nimport {\n  ClaudeAIWordmark,\n  CursorWordmark,\n  GoogleWordmark,\n  GrokWordmark,\n  OpenAIWordmark,\n  ReplicateWordmark,\n} from \"@aliimam/logos\"\n\nimport { Button } from \"@/components/ui/button\"\n\nconst Cta1 = () => {\n  return (\n    <section className=\"py-10\">\n      <div className=\"container\">\n        <div className=\"pointer-events-none absolute inset-0 overflow-hidden\">\n          <div className=\"absolute inset-0 border-x [mask-image:linear-gradient(black,transparent)]\"></div>\n          <div className=\"absolute inset-y-0 left-1/2 w-[1200px] -translate-x-1/2\">\n            <svg\n              className=\"pointer-events-none absolute inset-0 [mask-image:linear-gradient(black,transparent),radial-gradient(black,transparent)] [mask-composite:intersect] text-black/20 dark:text-white/20\"\n              width=\"100%\"\n              height=\"100%\"\n            >\n              <defs>\n                <pattern\n                  id=\"grid-pattern\"\n                  x=\"-1\"\n                  y=\"-1\"\n                  width=\"60\"\n                  height=\"60\"\n                  patternUnits=\"userSpaceOnUse\"\n                >\n                  <path\n                    d=\"M 60 0 L 0 0 0 60\"\n                    fill=\"transparent\"\n                    stroke=\"currentColor\"\n                    strokeWidth=\"1\"\n                  ></path>\n                </pattern>\n              </defs>\n              <rect fill=\"url(#grid-pattern)\" width=\"100%\" height=\"100%\"></rect>\n            </svg>\n          </div>\n        </div>\n        <div className=\"relative flex flex-col items-center px-4 pt-24 pb-32 text-center\">\n          <div className=\"mb-10 flex flex-wrap items-center justify-center gap-8\">\n            <a className=\"group flex items-center gap-2.5\">\n              <div className=\"bg-secondary flex size-8 shrink-0 items-center justify-center rounded-full\">\n                <Award className=\"h-3 w-auto\" />\n              </div>\n              <div className=\"flex items-center\">\n                {[...Array(5)].map((_, i) => (\n                  <Star\n                    key={i}\n                    className=\"size-4 shrink-0\"\n                    fill=\"currentColor\"\n                  />\n                ))}\n              </div>\n            </a>\n\n            <a className=\"group flex items-center gap-2.5\">\n              <div className=\"bg-secondary flex size-8 shrink-0 items-center justify-center rounded-full\">\n                <Cat className=\"h-3 w-auto\" />\n              </div>\n              <div className=\"flex items-center\">\n                {[...Array(5)].map((_, i) => (\n                  <Star\n                    key={i}\n                    className=\"size-4 shrink-0\"\n                    fill=\"currentColor\"\n                  />\n                ))}\n              </div>\n            </a>\n\n            <a className=\"group flex items-center gap-2.5\">\n              <div className=\"bg-secondary flex size-8 shrink-0 items-center justify-center rounded-full\">\n                <ShieldCheck className=\"h-3 w-auto\" />\n              </div>\n              <div className=\"flex items-center\">\n                {[...Array(4)].map((_, i) => (\n                  <Star\n                    key={i}\n                    className=\"size-4 shrink-0\"\n                    fill=\"currentColor\"\n                  />\n                ))}\n                <StarHalf className=\"size-4 shrink-0\" fill=\"currentColor\" />\n              </div>\n            </a>\n          </div>\n\n          {/* Headline and Description */}\n          <h2 className=\"font-display max-w-lg text-4xl font-medium text-balance sm:text-5xl\">\n            Transform your creative workflow\n          </h2>\n          <p className=\"text-muted-foreground mt-6 max-w-[560px] text-lg font-medium sm:text-xl\">\n            Start designing with ease and see how Ali Imam&apos;s tools\n            streamline your creative process for stunning results.\n          </p>\n\n          {/* Call-to-Action Buttons */}\n          <div className=\"mt-10 flex items-center justify-center gap-3\">\n            <Button>Start designing free</Button>\n            <Button variant=\"secondary\">Book a Demo</Button>\n          </div>\n          <div className=\"mt-10 grid grid-cols-3 items-center justify-center gap-x-16\">\n            <OpenAIWordmark size={100} />\n            <ClaudeAIWordmark size={100} />\n            <ReplicateWordmark size={100} />\n            <CursorWordmark size={100} />\n            <GrokWordmark size={90} />\n            <GoogleWordmark size={90} />\n          </div>\n        </div>\n      </div>\n    </section>\n  )\n}\n\nexport default Cta1\n", "type": "registry:component", "target": "components/cta.tsx"}], "meta": {"iframeHeight": "820px"}, "categories": ["cta"], "type": "registry:block"}
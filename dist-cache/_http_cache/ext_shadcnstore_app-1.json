ssName='flex items-center gap-4'>\n            {/* Sidebar toggler for mobile/tablet */}\n            <Button\n              variant='ghost'\n              size='icon'\n              className=\"size-9 me-2 cursor-pointer md:hidden\"\n              aria-label='Open sidebar'\n              onClick={() => setSidebarOpen(true)}\n            >\n              <Menu />\n            </Button>\n            <h1 className='hidden md:block text-xl font-semibold text-balance'>Welcome back, John!</h1>\n          </div>\n          <div className='flex items-center gap-2'>\n            <Button variant='ghost' size='icon' className=\"size-9 cursor-pointer\">\n              <Search />\n            </Button>\n            <Button variant='ghost' size='icon' className=\"size-9 cursor-pointer\">\n              <Bell />\n            </Button>\n            <Button variant='ghost' className=\"h-9 px-4 py-2 flex cursor-pointer items-center\">\n              <Avatar className='bg-muted size-8'>\n                <AvatarImage src='https://notion-avatars.netlify.app/api/avatar' />\n                <AvatarFallback>JD</AvatarFallback>\n              </Avatar>\n              <ChevronDown />\n            </Button>\n          </div>\n        </header>\n\n        {/* Main Content Area */}\n        <main className='flex-1 overflow-auto p-6'>\n          <div className='flex flex-col gap-6'>\n            {/* Stats Cards */}\n            <div className='grid gap-4 sm:grid-cols-2 lg:grid-cols-4'>\n              <Card>\n                <CardHeader className='flex flex-row items-center justify-between space-y-0 pb-2'>\n                  <CardTitle className='text-sm font-medium text-balance'>Total Projects</CardTitle>\n                  <FileText className='text-muted-foreground size-5' />\n                </CardHeader>\n                <CardContent>\n                  <div className='text-2xl font-bold'>24</div>\n                  <p className='text-muted-foreground text-xs'>+2 from last month</p>\n                </CardContent>\n              </Card>\n              <Card>\n                <CardHeader className='flex flex-row items-center justify-between space-y-0 pb-2'>\n                  <CardTitle className='text-sm font-medium text-balance'>Active Tasks</CardTitle>\n                  <ClipboardList className='text-muted-foreground size-5' />\n                </CardHeader>\n                <CardContent>\n                  <div className='text-2xl font-bold'>127</div>\n                  <p className='text-muted-foreground text-xs'>+12 from yesterday</p>\n                </CardContent>\n              </Card>\n              <Card>\n                <CardHeader className='flex flex-row items-center justify-between space-y-0 pb-2'>\n                  <CardTitle className='text-sm font-medium text-balance'>Team Members</CardTitle>\n                  <Users className='text-muted-foreground size-5' />\n                </CardHeader>\n                <CardContent>\n                  <div className='text-2xl font-bold'>16</div>\n                  <p className='text-muted-foreground text-xs'>+1 new member</p>\n                </CardContent>\n              </Card>\n              <Card>\n                <CardHeader className='flex flex-row items-center justify-between space-y-0 pb-2'>\n                  <CardTitle className='text-sm font-medium text-balance'>Completion Rate</CardTitle>\n                  <BarChart3 className='text-muted-foreground size-5' />\n                </CardHeader>\n                <CardContent>\n                  <div className='text-2xl font-bold'>87%</div>\n                  <p className='text-muted-foreground text-xs'>+5% from last week</p>\n                </CardContent>\n              </Card>\n            </div>\n\n            <div className='grid gap-6 lg:grid-cols-2'>\n              {/* Active Projects */}\n              <Card>\n                <CardHeader>\n                  <CardTitle className='text-balance'>Active Projects</CardTitle>\n                  <CardDescription>Your current project progress</CardDescription>\n                </CardHeader>\n                <CardContent className='flex flex-col gap-4'>\n                  {projects.map((project, index) => (\n                    <div key={index} className='flex flex-col gap-2'>\n                      <div className='flex items-center justify-between'>\n                        <h4 className='text-sm font-medium'>{project.name}</h4>\n                        <Badge\n                          variant={\n                            project.status === 'In Progress'\n                              ? 'default'\n                              : project.status === 'Review'\n                                ? 'secondary'\n                                : 'outline'\n                          }\n                         className=\"px-2.5 py-0.5 font-semibold\">\n                          {project.status}\n                        </Badge>\n                      </div>\n                      <p className='text-muted-foreground text-xs'>{project.description}</p>\n                      <div className='flex items-center justify-between'>\n                        <Progress value={project.progress} className='flex-1' />\n                        <span className='text-muted-foreground ms-3 text-xs'>{project.progress}%</span>\n                      </div>\n                      <div className='flex items-center justify-between'>\n                        <div className='flex -space-x-2'>\n                          {project.team.map((member, memberIndex) => (\n                            <Avatar key={memberIndex} className='bg-muted size-6 border'>\n                              <AvatarImage\n                                src={`https://notion-avatars.netlify.app/api/avatar?preset=male-${memberIndex}`}\n                              />\n                              <AvatarFallback className='text-xs'>{member}</AvatarFallback>\n                            </Avatar>\n                          ))}\n                        </div>\n                        <span className='text-muted-foreground text-xs'>Due {project.dueDate}</span>\n                      </div>\n                    </div>\n                  ))}\n                </CardContent>\n              </Card>\n\n              {/* Recent Activity */}\n              <Card>\n                <CardHeader>\n                  <CardTitle className='text-balance'>Recent Activity</CardTitle>\n                  <CardDescription>Latest updates from your team</CardDescription>\n                </CardHeader>\n                <CardContent>\n                  <div className='flex flex-col gap-4'>\n                    {recentActivity.map((activity, index) => (\n                      <div key={index} className='flex items-start gap-3'>\n                        <Avatar className='bg-muted size-8 border'>\n                          <AvatarImage src={activity.avatar} />\n                          <AvatarFallback className='text-xs'>{activity.avatar}</AvatarFallback>\n                        </Avatar>\n                        <div className='min-w-0 flex-1'>\n                          <p className='text-sm'>\n                            <span className='font-medium'>{activity.user}</span>{' '}\n                            <span className='text-muted-foreground'>{activity.action}</span>\n                          </p>\n                          <p className='text-muted-foreground text-xs'>{activity.time}</p>\n                        </div>\n                      </div>\n                    ))}\n                  </div>\n                </CardContent>\n              </Card>\n            </div>\n          </div>\n        </main>\n      </div>\n    </div>\n  )\n}\n", "type": "registry:block", "target": "src/components/app-1.tsx"}], "type": "registry:block"}
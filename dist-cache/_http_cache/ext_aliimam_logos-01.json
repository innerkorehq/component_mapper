nt(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.45) 100%)\",\n            pointerEvents: \"none\",\n            position: \"absolute\",\n            width: \"100%\",\n          }}\n        />\n      </div>\n    </div>\n  )\n}\n", "type": "registry:component", "target": "components/logos-01.tsx"}], "meta": {"iframeHeight": "500px"}, "categories": ["logos"], "type": "registry:block"}
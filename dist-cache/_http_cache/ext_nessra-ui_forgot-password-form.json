{"$schema": "https://ui.shadcn.com/schema/registry-item.json", "name": "forgot-password-form", "title": "Forgot Password Form", "description": "A forgot password page with email input and success state.", "dependencies": ["@tanstack/react-form", "lucide-react", "zod"], "registryDependencies": ["https://nessra-ui.vercel.app/r/button.json", "https://nessra-ui.vercel.app/r/card.json", "https://nessra-ui.vercel.app/r/input-group.json", "https://nessra-ui.vercel.app/r/form.json", "https://nessra-ui.vercel.app/r/spinner.json", "https://nessra-ui.vercel.app/r/alert.json"], "files": [{"path": "registry/new-york/blocks/forgot-password-form.tsx", "content": "/* eslint-disable @next/next/no-html-link-for-pages, @next/next/no-img-element */\n\"use client\"\n\nimport { useState } from \"react\"\nimport { useForm } from \"@tanstack/react-form\"\nimport { ArrowLeft, CheckCircle, Mail } from \"lucide-react\"\nimport { z } from \"zod\"\n\nimport { Alert, AlertDescription } from \"@/components/ui/alert\"\nimport { Button } from \"@/components/ui/button\"\nimport {\n  Card,\n  CardContent,\n  CardDescription,\n  CardHeader,\n  CardTitle,\n} from \"@/components/ui/card\"\nimport {\n  Form,\n  FormControl,\n  FormField,\n  FormLabel,\n  FormMessage,\n} from \"@/components/ui/form\"\nimport {\n  InputGroup,\n  InputGroupAddon,\n  InputGroupInput,\n} from \"@/components/ui/input-group\"\nimport { Spinner } from \"@/components/ui/spinner\"\n\nconst forgotPasswordSchema = z.object({\n  email: z.email(\"Please enter a valid email\"),\n})\n\nexport function ForgotPasswordForm() {\n  const [isSubmitted, setIsSubmitted] = useState(false)\n\n  const form = useForm({\n    defaultValues: {\n      email: \"\",\n    },\n    validators: {\n      onChange: forgotPasswordSchema,\n    },\n    onSubmit: async ({ value }) => {\n      // Simulate API call - replace with your auth logic\n      await new Promise((resolve) => setTimeout(resolve, 2000))\n      console.log(\"Reset password request for:\", value.email)\n      setIsSubmitted(true)\n    },\n  })\n\n  return (\n    <div className=\"bg-muted/50 flex min-h-screen w-full flex-col items-center justify-center p-4\">\n      {/* Logo */}\n      <div className=\"mb-8\">\n        <a href=\"/\" className=\"flex items-center gap-2\">\n          <img src=\"/nessra-ui-logo.svg\" alt=\"nessra ui\" className=\"size-14\" />\n        </a>\n      </div>\n\n      {/* Card */}\n      {isSubmitted ? (\n        <Card className=\"w-full max-w-md\">\n          <CardHeader className=\"text-center\">\n            <CardTitle className=\"text-2xl\">Check your email</CardTitle>\n            <CardDescription>\n              We&apos;ve sent you a password reset link\n            </CardDescription>\n          </CardHeader>\n          <CardContent>\n            <Alert className=\"border-green-500 bg-green-50 text-green-700 dark:bg-green-950 dark:text-green-300\">\n              <CheckCircle className=\"size-4\" />\n              <AlertDescription>\n                If an account exists with this email, you will receive a\n                password reset link shortly.\n              </AlertDescription>\n            </Alert>\n\n            <Button variant=\"outline\" className=\"mt-6 w-full\" asChild>\n              <a href=\"/sign-in\">\n                <ArrowLeft className=\"size-4\" />\n                Back to sign in\n              </a>\n            </Button>\n          </CardContent>\n        </Card>\n      ) : (\n        <Card className=\"w-full max-w-md\">\n          <CardHeader className=\"text-center\">\n            <CardTitle className=\"text-2xl\">Forgot password?</CardTitle>\n            <CardDescription>\n              Enter your email and we&apos;ll send you a reset link\n            </CardDescription>\n          </CardHeader>\n          <CardContent>\n            <Form\n              onSubmit={(e) => {\n                e.preventDefault()\n                form.handleSubmit()\n              }}\n            >\n              <form.Field name=\"email\">\n                {(field) => (\n                  <FormField\n                    name={field.name}\n                    errors={field.state.meta.errors}\n                    isTouched={field.state.meta.isTouched}\n                  >\n                    <FormLabel>Email</FormLabel>\n                    <FormControl>\n                      <InputGroup>\n                        <InputGroupAddon>\n                          <Mail className=\"size-4\" />\n                        </InputGroupAddon>\n                        <InputGroupInput\n                          type=\"email\"\n                          placeholder=\"you@example.com\"\n                          value={field.state.value}\n                          onBlur={field.handleBlur}\n                          onChange={(e) => field.handleChange(e.target.value)}\n                        />\n                      </InputGroup>\n                    </FormControl>\n                    <FormMessage />\n                  </FormField>\n                )}\n              </form.Field>\n\n              <form.Subscribe selector={(s) => [s.canSubmit, s.isSubmitting]}>\n                {([canSubmit, isSubmitting]) => (\n                  <Button\n                    type=\"submit\"\n                    className=\"mt-6 w-full\"\n                    disabled={!canSubmit || isSubmitting}\n                  >\n                    {isSubmitting ? (\n                      <>\n                        <Spinner />\n                        Sending...\n                      </>\n                    ) : (\n                      \"Send reset link\"\n                    )}\n                  </Button>\n                )}\n              </form.Subscribe>\n\n              <p className=\"text-muted-foreground mt-6 text-center text-sm\">\n                Remember your password?{\" \"}\n                <a\n                  href=\"/sign-in\"\n                  className=\"text-primary font-medium underline-offset-4 hover:underline\"\n                >\n                  Sign in\n                </a>\n              </p>\n            </Form>\n          </CardContent>\n        </Card>\n      )}\n\n      {/* Footer */}\n      <p className=\"text-muted-foreground mt-8 text-center text-xs\">\n        \u00a9 2025 nessra ui. All rights reserved.\n      </p>\n    </div>\n  )\n}\n", "type": "registry:block"}, {"path": "registry/new-york/assets/nessra-ui-logo.svg", "content": "<svg xmlns=\"http://www.w3.org/2000/svg\" shape-rendering=\"geometricPrecision\" text-rendering=\"geometricPrecision\" image-rendering=\"optimizeQuality\" fill-rule=\"evenodd\" clip-rule=\"evenodd\" viewBox=\"0 0 503 511.736\"><g fill-rule=\"nonzero\"><path fill=\"#330910\" d=\"M210.486 50.67c5.366-6.068 12.39-12.545 22.522-20.094 13.678-10.184 27.882-17.868 42.576-23.025 47.2-16.561 114.303-5.165 153.128 27.175 12.655 10.549 23.711 23.242 33.135 38.045 9.325 14.641 17.047 31.272 23.151 49.869 6.004 18.28 10.514 38.205 13.513 59.745 2.987 21.466 4.489 44.348 4.489 68.631 0 11.573-.278 23.759-.825 36.538-.547 12.693-1.32 24.722-2.305 36.07a775.858 775.858 0 01-3.755 34.263c-1.441 10.97-3.086 21.371-4.909 31.173-1.871 10.036-4.033 19.239-6.473 27.583-2.504 8.565-5.318 16.23-8.413 22.981-4.662 10.705-10.305 20.06-16.925 28.047-21.454 25.859-52.717 37.163-85.878 37.163-27.327 0-59.177-9.78-76.758-31.663-7.444-9.268-13.005-20.242-16.678-32.905-3.546-12.232-5.322-25.881-5.322-40.922 0-7.176.213-15.763.634-25.742.408-9.776.99-19.7 1.727-29.758l2.206-31.216 2.014-30.838c.651-10.549 1.142-19.778 1.432-27.618.283-7.449.426-14.833.426-22.139 0-18.397-2.444-31.689-7.323-39.85-1.476-2.471-3.282-4.42-5.422-5.839-4.059.143-7.775 1.163-11.135 3.065h-.056c-3.881 2.196-7.575 5.613-11.066 10.249l-.503.738c-3.99 5.456-7.354 12.168-10.071 20.107-2.817 8.24-4.936 17.621-6.338 28.117l-.091 1.072c-.755 6.06-1.411 12.75-1.958 20.051a748.56 748.56 0 00-1.433 24.822l-2.305 54.87c-.412 9.763-.833 18.211-1.25 25.321-.49 8.357-.972 15.359-1.437 20.95
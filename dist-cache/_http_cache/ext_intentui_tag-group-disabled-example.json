{"$schema": "https://ui.shadcn.com/schema/registry-item.json", "extends": "none", "name": "tag-group-disabled-example", "title": "Tag Group Disabled", "description": "tag-group-disabled-example", "registryDependencies": ["https://intentui.com/r/field", "https://intentui.com/r/tag-group"], "files": [{"path": "src/components/examples/collections/tag-group/tag-group-disabled-example.tsx", "content": "\"use client\"\n\nimport { androidBrands } from \"@/components/examples/collections/tag-group/tag-group-example\"\nimport { Label } from \"@/components/ui/field\"\nimport { Tag, TagGroup, TagList } from \"@/components/ui/tag-group\"\n\nexport default function TagGroupDisabledDemo() {\n  return (\n    <div className=\"space-y-6\">\n      <TagGroup\n        disabledKeys={androidBrands.filter((brand) => !brand.available).map((brand) => brand.id)}\n        selectionMode=\"multiple\"\n      >\n        <Label>Disabled key</Label>\n        <TagList items={androidBrands}>{(item) => <Tag>{item.name}</Tag>}</TagList>\n      </TagGroup>\n\n      <TagGroup selectionMode=\"multiple\">\n        <Label>Disabled by Tag</Label>\n        <TagList items={androidBrands}>\n          {(item) => <Tag isDisabled={item.available}>{item.name}</Tag>}\n        </TagList>\n      </TagGroup>\n    </div>\n  )\n}\n", "type": "registry:page", "target": "app/tag-group-disabled-example/page.tsx"}], "type": "registry:page"}
{"$schema": "https://ui.shadcn.com/schema/registry-item.json", "name": "checkout-form-1", "title": "Simple Checkout Form 1", "description": "A clean and straightforward checkout form with essential fields", "dependencies": ["lucide-react"], "registryDependencies": ["badge", "button", "card", "checkbox", "input", "label", "radio-group", "select", "separator"], "files": [{"path": "resources/js/components/blocks/e-commerce/checkout-forms/CheckoutForm1.tsx", "content": "'use client'\n\nimport { useState } from 'react'\nimport { Badge } from '@/components/ui/badge'\nimport { Button } from '@/components/ui/button'\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card'\nimport { Checkbox } from '@/components/ui/checkbox'\nimport { Input } from '@/components/ui/input'\nimport { Label } from '@/components/ui/label'\nimport { RadioGroup, RadioGroupItem } from '@/components/ui/radio-group'\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select'\nimport { Separator } from '@/components/ui/separator'\nimport { ArrowLeft, CreditCard, Eye, EyeOff, Gift, Lock, Shield, Tag, Truck } from 'lucide-react'\n\nexport default function CheckoutForm1() {\n  const [step, setStep] = useState(1)\n  const [showCvv, setShowCvv] = useState(false)\n  const [formData, setFormData] = useState({\n    // Personal Information\n    email: '',\n    firstName: '',\n    lastName: '',\n    phone: '',\n\n    // Shipping Address\n    address: '',\n    city: '',\n    state: '',\n    zipCode: '',\n    country: 'US',\n\n    // Payment\n    cardNumber: '',\n    expiryDate: '',\n    cvv: '',\n    cardName: '',\n\n    // Options\n    saveInfo: false,\n    sameAsBilling: true,\n    newsletter: false,\n    promoCode: '',\n  })\n\n  const [orderSummary] = useState({\n    items: [\n      {\n        id: 1,\n        name: 'Premium Wireless Headphones',\n        variant: 'Midnight Black',\n        price: 299.99,\n        quantity: 1,\n        image: 'https://assets.shadcnstore.com/shadcnstore.com/stock/e-commerce/premium-wireless-headphones.600w.7d1414.avif',\n      },\n      {\n        id: 2,\n        name: 'Leather Laptop Sleeve',\n        variant: 'Brown, 13-inch',\n        price: 89.99,\n        quantity: 1,\n        image: 'https://assets.shadcnstore.com/shadcnstore.com/stock/e-commerce/leather-laptop-sleeve.800w.86ef12.avif',\n      },\n    ],\n    shipping: 15.99,\n    tax: 27.54,\n    discount: 0,\n    promoDiscount: 0,\n  })\n\n  const handleInputChange = (field: string, value: string | boolean) => {\n    setFormData(prev => ({ ...prev, [field]: value }))\n  }\n\n  const handleCardNumberChange = (value: string) => {\n    // Format card number with spaces\n    const formatted = value\n      .replace(/\\s/g, '')\n      .replace(/(.{4})/g, '$1 ')\n      .trim()\n    handleInputChange('cardNumber', formatted)\n  }\n\n  const handleExpiryChange = (value: string) => {\n    // Format expiry as MM/YY\n    const formatted = value.replace(/\\D/g, '').replace(/(\\d{2})(\\d)/, '$1/$2')\n    handleInputChange('expiryDate', formatted)\n  }\n\n  const subtotal = orderSummary.items.reduce((sum, item) => sum + item.price * item.quantity, 0)\n  const total = subtotal + orderSummary.shipping + orderSummary.tax - orderSummary.discount - orderSummary.promoDiscount\n\n  const nextStep = () => setStep(prev => Math.min(prev + 1, 3))\n  const prevStep = () => setStep(prev => Math.max(prev - 1, 1))\n\n  return (\n    <div className='bg-muted/30'>\n      <div className='mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 py-8'>\n        {/* Header */}\n        <div className='mb-8 text-center'>\n          <h1 className='mb-2 text-3xl font-bold text-balance'>Secure Checkout</h1>\n          <p className='text-muted-foreground'>Complete your purchase in just a few steps</p>\n        </div>\n\n        {/* Progress Indicator */}\n        <div className='mb-8 flex justify-center'>\n          <div className='flex items-center gap-4'>\n            {[1, 2, 3].map(stepNumber => (\n              <div key={stepNumber} className='flex items-center'>\n                <div\n                  className={`flex size-10 items-center justify-center rounded-full text-sm font-medium transition-colors ${\n                    stepNumber <= step ? 'bg-primary text-primary-foreground' : 'bg-muted text-muted-foreground'\n                  }`}\n                >\n                  {stepNumber}\n                </div>\n                {stepNumber < 3 ? (\n                  <div\n                    className={`mx-4 h-1 w-16 rounded transition-colors ${\n                      stepNumber < step ? 'bg-primary' : 'bg-muted'\n                    }`}\n                  />\n                ) : null}\n              </div>\n            ))}\n          </div>\n        </div>\n\n        <div className='grid gap-8 lg:grid-cols-3'>\n          {/* Main Form */}\n          <div className='lg:col-span-2'>\n            <Card>\n              <CardHeader>\n                <CardTitle className='text-balance'>\n                  {step === 1 && 'Contact Information'}\n                  {step === 2 && 'Shipping Address'}\n                  {step === 3 && 'Payment Details'}\n                </CardTitle>\n                <CardDescription>\n                  {step === 1 && \"We'll use this to send you order updates\"}\n                  {step === 2 && 'Where should we deliver your order?'}\n                  {step === 3 && 'Your payment information is secure and encrypted'}\n                </CardDescription>\n              </CardHeader>\n              <CardContent className='flex flex-col gap-6'>\n                {/* Step 1: Contact Information */}\n                {step === 1 ? (\n                  <div className='flex flex-col gap-4'>\n                    <div className='flex flex-col gap-2'>\n                      <Label htmlFor='email-kL9x23P'>Email address</Label>\n                      <Input\n                        id='email-kL9x23P'\n                        type='email'\n                        placeholder='john@example.com'\n                        value={formData.email}\n                        onChange={e => handleInputChange('email', e.target.value)}\n                        className='h-9'\n                      />\n                    </div>\n\n                    <div className='grid gap-4 md:grid-cols-2'>\n                      <div className='flex flex-col gap-2'>\n                        <Label htmlFor='firstName-mN7z84Q'>First name</Label>\n                        <Input\n                          id='firstName-mN7z84Q'\n                          placeholder='John'\n                          value={formData.firstName}\n                          onChange={e => handleInputChange('firstName', e.target.value)}\n                          className='h-9'\n                        />\n                      </div>\n                      <div className='flex flex-col gap-2'>\n                        <Label htmlFor='lastName-pL8w45T'>Last name</Label>\n                        <Input\n                          id='lastName-pL8w45T'\n                          placeholder='Doe'\n                          value={formData.lastName}\n                          onChange={e => handleInputChange('lastName', e.target.value)}\n                          className='h-9'\n                        />\n                      </div>\n                    </div>\n\n                    <div className='flex flex-col gap-2'>\n                      <Label htmlFor='phone-rM6n82S'>Phone number (optional)</Label>\n                      <Input\n                        id='phone-rM6n82S'\n                        type='tel'\n                        placeholder='+1 (555) 123-4567'\n                        value={formData.phone}\n                        onChange={e => handleInputChange('phone', e.target.value)}\n                        className='h-9'\n                      />\n                    </div>\n                  </div>\n                ) : null}\n\n                {/* Step 2: Shipping Address */}\n                {step === 2 ? (\n                  <div className='flex flex-col gap-4'>\n                    <div className='flex flex-col gap-2'>\n                      <Label htmlFor='address-qP4z17X'>Street address</Label>\n                      <Input\n                        id='address-qP4z17X'\n                        placeholder='123 Main Street'\n                        value={formData.address}\n                        onChange={e => handleInputChange('address', e.target.value)}\n                        className='h-9'\n                      />\n                    </div>\n\n                    <div className='grid gap-4 md:grid-cols-2'>\n                      <div className='flex flex-col gap-2'>\n                        <Label htmlFor='city-sT5y91B'>City</Label>\n                        <Input\n                          id='city-sT5y91B'\n                          placeholder='New York'\n                          value={formData.city}\n                          onChange={e => handleInputChange('city', e.target.value)}\n                          className='h-9'\n                        />\n                      </div>\n                      <div className='flex flex-col gap-2'>\n                        <Label htmlFor='state-wX3k85M'>State</Label>\n                        <Input\n                          id='state-wX3k85M'\n                          placeholder='NY'\n                          value={formData.state}\n                          onChange={e => handleInputChange('state', e.target.value)}\n                          className='h-9'\n                        />\n                      </div>\n                    </div>\n\n                    <div className='grid gap-4 md:grid-cols-2'>\n                      <div className='flex flex-col gap-2'>\n                        <Label htmlFor='zipCode-vZ9q46N'>ZIP code</Label>\n                        <Input\n                          id='zipCode-vZ9q46N'\n                          placeholder='10001'\n                          value={formData.zipCode}\n                          onChange={e => handleInputChange('zipCode', e.target.value)}\n                          className='h-9'\n                        />\n                      </div>\n                      <div className='flex flex-col gap-2'>\n                        <Label htmlFor='country-bH7l52P'>Country</Label>\n                        <Select value={formData.country} onValueChange={value => handleInputChange('country', value)}>\n                          <SelectTrigger id='country-bH7l52P' className='mt-2 py-3 !h-9 w-full'>\n                            <SelectValue />\n                          </SelectTrigger>\n                          <SelectContent position=\"popper\">\n                            <SelectItem value='US'>United States</SelectItem>\n                            <SelectItem value='CA'>Canada</SelectItem>\n                            <SelectItem value='UK'>United Kingdom</SelectItem>\n                            <SelectItem value='AU'>Australia</SelectItem>\n                          </SelectContent>\n                        </Select>\n                      </div>\n                    </div>\n                  </div>\n                ) : null}\n\n                {/* Step 3: Payment */}\n                {step === 3 ? (\n                  <div className='flex flex-col gap-6'>\n                    {/* Payment Method */}\n                    <div className='flex flex-col gap-4'>\n                      <Label className='text-sm font-medium'>Payment method</Label>\n                      <RadioGroup defaultValue='card' className='flex flex-col gap-3'>\n                        <div className='flex items-center gap-3 rounded-lg border p-4'>\n                          <RadioGroupItem value='card' id='card-payment-cN9m74K' />\n                          <CreditCard className='text-muted-foreground size-5' />\n                          <Label htmlFor='card-payment-cN9m74K' className='flex-1 cursor-pointer'>\n                            Credit or debit card\n                          </Label>\n                        </div>\n                      </RadioGroup>\n                    </div>\n\n                    {/* Card Details */}\n                    <div className='flex flex-col gap-4'>\n                      <div className='flex flex-col gap-2'>\n                        <Label htmlFor='cardNumber-dK5p83L'>Card number</Label>\n                        <Input\n                          id='cardNumber-dK5p83L'\n                          placeholder='1234 5678 9012 3456'\n                          value={formData.cardNumber}\n                          onChange={e => handleCardNumberChange(e.target.value)}\n                          maxLength={19}\n                          className='h-9'\n                        />\n                      </div>\n\n                      <div className='grid gap-4 md:grid-cols-3'>\n                        <div className='flex flex-col gap-2'>\n                          <Label htmlFor='expiryDate-fJ6r29M'>Expiry</Label>\n                          <Input\n                            id='expiryDate-fJ6r29M'\n                            placeholder='MM/YY'\n                            value={formData.expiryDate}\n                            onChange={e => handleExpiryChange(e.target.value)}\n                            maxLength={5}\n                            className='h-9'\n                          />\n                        </div>\n                        <div className='flex flex-col gap-2'>\n                          <Label htmlFor='cvv-gH8s34N'>CVV</Label>\n                          <div className='relative'>\n                            <Input\n                              id='cvv-gH8s34N'\n                              type={showCvv ? 'text' : 'password'}\n                              placeholder='123'\n                              value={formData.cvv}\n                              onChange={e => handleInputChange('cvv', e.target.value)}\n                              maxLength={4}\n                              className='h-9 pe-10'\n                            />\n                            <Button\n                              type='button'\n                              variant='ghost'\n                              size='icon'\n                              className=\"h-9 w-9 absolute end-0 top-1/2 h-full -translate-y-1/2 cursor-pointer hover:bg-transparent\"\n                              onClick={() => setShowCvv(!showCvv)}\n                            >\n                              {showCvv ? (\n                                <EyeOff className='text-muted-foreground size-4' />\n                              ) : (\n                                <Eye className='text-muted-foreground size-4' />\n                              )}\n                            </Button>\n                          </div>\n                        </div>\n                        <div className='flex flex-col gap-2'>\n                          <Label htmlFor='cardName-hI9t45O'>Name on card</Label>\n                          <Input\n                            id='cardName-hI9t45O'\n                            placeholder='John Doe'\n                            value={formData.cardName}\n                            onChange={e => handleInputChange('cardName', e.target.value)}\n                            className='h-9'\n                          />\n                        </div>\n                      </div>\n                    </div>\n\n                    {/* Additional Options */}\n                    <div className='flex flex-col gap-4'>\n                      <div className='flex items-center gap-2'>\n                        <Checkbox\n                          id='saveInfo-jK0u56P'\n                          checked={formData.saveInfo}\n                          onCheckedChange={checked => handleInputChange('saveInfo', checked as boolean)}\n                        />\n                        <Label htmlFor='saveInfo-jK0u56P' className='text-sm'>\n                          Save payment information for future purchases\n                        </Label>\n                      </div>\n                    </div>\n                  </div>\n                ) : null}\n\n                {/* Navigation Buttons */}\n                <div className='flex justify-between pt-6'>\n                  <Button\n                    type='button'\n                    variant='outline'\n                    onClick={prevStep}\n                    disabled={step === 1}\n                    className=\"h-9 px-4 py-2 flex cursor-pointer items-center gap-2\"\n                  >\n                    <ArrowLeft className='size-4' />\n                    Back\n                  </Button>\n\n                  {step < 3 ? (\n                    <Button onClick={nextStep} className=\"h-9 px-4 py-2 cursor-pointer\">\n                      Continue\n                    </Button>\n                  ) : (\n                    <Button className=\"h-9 px-4 py-2 flex cursor-pointer items-center gap-2\">\n                      <Lock className='size-4' />\n                      Complete Order\n                    </Button>\n                  )}\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n\n          {/* Order Summary */}\n          <div className='lg:col-span-1'>\n            <Card className='sticky top-8'>\n              <CardHeader>\n                <CardTitle className='text-balance'>Order Summary</CardTitle>\n              </CardHeader>\n              <CardContent className='flex flex-col gap-4'>\n                {/* Items */}\n                <div className='flex flex-col gap-4'>\n                  {orderSummary.items.map(item => (\n                    <div key={item.id} className='flex gap-4'>\n                      <div className='relative'>\n                        <img src={item.image} alt={item.name} className='size-16 rounded-lg object-cover' />\n                        <Badge variant='secondary' className=\"px-2.5 py-0.5 font-semibold absolute -end-2 -top-2 size-6 rounded-full p-0 text-xs\">\n                          {item.quantity}\n                        </Badge>\n                      </div>\n                      <div className='min-w-0 flex-1'>\n                        <h4 className='truncate text-sm font-medium'>{item.name}</h4>\n                        <p className='text-muted-foreground text-xs'>{item.variant}</p>\n                        <p className='mt-1 text-sm font-medium'>${item.price}</p>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n\n                <Separator />\n\n                {/* Promo Code */}\n                <div className='flex flex-col gap-2'>\n                  <Label htmlFor='promoCode-kL1m67Q' className='text-sm'>\n                    Promo code\n                  </Label>\n                  <div className='flex gap-2'>\n                    <Input\n                      id='promoCode-kL1m67Q'\n                      placeholder='Enter code'\n                      value={formData.promoCode}\n                      className='h-9'\n                      onChange={e => handleInputChange('promoCode', e.target.value)}\n                    />\n                    <Button variant='outline' className=\"h-9 px-4 py-2 cursor-pointer\">\n                      Apply\n                    </Button>\n                  </div>\n                </div>\n\n                <Separator />\n\n                {/* Pricing Breakdown */}\n                <div className='flex flex-col gap-2'>\n                  <div className='flex justify-between text-sm'>\n                    <span className='text-muted-foreground'>Subtotal</span>\n                    <span>${subtotal.toFixed(2)}</span>\n                  </div>\n                  <div className='flex justify-between text-sm'>\n                    <span className='text-muted-foreground flex items-center gap-1'>\n                      <Truck className='size-3' />\n                      Shipping\n                    </span>\n                    <span>${orderSummary.shipping.toFixed(2)}</span>\n                  </div>\n                  <div className='flex justify-between text-sm'>\n                    <span className='text-muted-foreground'>Tax</span>\n                    <span>${orderSummary.tax.toFixed(2)}</span>\n                  </div>\n                  {orderSummary.promoDiscount > 0 ? (\n                    <div className='flex justify-between text-sm text-green-600'>\n                      <span className='flex items-center gap-1'>\n                        <Tag className='size-3' />\n                        Promo discount\n                      </span>\n                      <span>-${orderSummary.promoDiscount.toFixed(2)}</span>\n                    </div>\n                  ) : null}\n                </div>\n\n                <Separator />\n\n                <div className='flex justify-between font-semibold'>\n                  <span>Total</span>\n                  <span>${total.toFixed(2)}</span>\n                </div>\n\n                {/* Trust Indicators */}\n                <div className='flex flex-col gap-3 pt-4'>\n                  <div className='text-muted-foreground flex items-center gap-2 text-xs'>\n                    <Shield className='size-4 text-green-600' />\n                    <span>SSL encrypted checkout</span>\n                  </div>\n                  <div className='text-muted-foreground flex items-center gap-2 text-xs'>\n                    <Truck className='size-4 text-blue-600' />\n                    <span>Free shipping on orders over $75</span>\n                  </div>\n                  <div className='text-muted-foreground flex items-center gap-2 text-xs'>\n                    <Gift className='size-4 text-purple-600' />\n                    <span>30-day return policy</span>\n                  </div>\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n        </div>\n      </div>\n    </div>\n  )\n}\n", "type": "registry:block", "target": "src/components/checkout-form-1.tsx"}], "type": "registry:block"}
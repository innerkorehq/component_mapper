{"$schema": "https://ui.shadcn.com/schema/registry-item.json", "name": "bento-grid-1", "title": "Bento Grid 1", "description": "A responsive grid of listings", "dependencies": ["lucide-react"], "registryDependencies": ["badge", "button", "card", "tabs"], "files": [{"path": "resources/js/components/blocks/marketing/bento-grids/BentoGrid1.tsx", "content": "'use client'\n\nimport { Button } from '@/components/ui/button'\nimport { Card, CardContent } from '@/components/ui/card'\nimport { Tabs, TabsList, TabsTrigger } from '@/components/ui/tabs'\nimport { Badge } from '@/components/ui/badge'\nimport { Heart, SlidersHorizontal, Star } from 'lucide-react'\nimport { useState } from 'react'\n\nconst regions = [\n  { id: 'top-rated', label: 'Top Rated' },\n  { id: 'italy', label: 'Italy' },\n  { id: 'dubai', label: 'Dubai' },\n  { id: 'london', label: 'London' },\n] as const\n\nconst destinations = [\n  {\n    id: 1,\n    title: 'Italy',\n    location: 'Italy',\n    image: 'https://assets.shadcnstore.com/shadcnstore.com/stock/marketing/professional-outdoor-adventure-gear-and-equipment.1200w.4ed779.avif',\n    price: 504,\n    rating: 5,\n  },\n  {\n    id: 2,\n    title: 'Dubai',\n    location: 'Dubai',\n    image: 'https://assets.shadcnstore.com/shadcnstore.com/stock/marketing/venice-canals-with-gondolas-2.800w.387c6a.avif',\n    price: 421,\n    rating: 5,\n  },\n  {\n    id: 3,\n    title: 'Maldives',\n    location: 'Maldives',\n    image: 'https://assets.shadcnstore.com/shadcnstore.com/stock/marketing/maldives.500w.ff09c7.avif',\n    price: 254,\n    rating: 5,\n  },\n  {\n    id: 4,\n    title: 'Sezaland',\n    location: 'Sezaland',\n    image: 'https://assets.shadcnstore.com/shadcnstore.com/stock/marketing/historic-edinburgh-castle-on-hill.800w.209186.avif',\n    price: 504,\n    rating: 5,\n  },\n  {\n    id: 5,\n    title: 'London',\n    location: 'London',\n    image: 'https://assets.shadcnstore.com/shadcnstore.com/stock/marketing/sheikh-zayed-grand-mosque.800w.fd1148.avif',\n    price: 214,\n    rating: 5,\n  },\n  {\n    id: 6,\n    title: 'America',\n    location: 'America',\n    image: 'https://assets.shadcnstore.com/shadcnstore.com/stock/marketing/american-flag-patriotic.500w.31382f.avif',\n    price: 898,\n    rating: 5,\n  },\n]\n\nexport default function BentoGrid1() {\n  const [activeRegion, setActiveRegion] = useState<(typeof regions)[number]['id']>('top-rated')\n  const [favorites, setFavorites] = useState<number[]>([])\n\n  const toggleFavorite = (id: number) => {\n    setFavorites(prev => (prev.includes(id) ? prev.filter(favId => favId !== id) : [...prev, id]))\n  }\n\n  return (\n    <section className='w-full'>\n      <div className='mx-auto w-full max-w-7xl px-4 py-12 sm:px-6 lg:px-8'>\n        {/* Header */}\n        <div className='mb-8 flex flex-col gap-2 text-center sm:mb-12 lg:mb-16'>\n          <h2 className='text-3xl tracking-tight sm:text-4xl lg:text-5xl'>\n            <span className='text-foreground font-bold'>Top</span>{' '}\n            <span className='text-foreground font-semibold'>Destinations</span>\n          </h2>\n          <p className='text-muted-foreground mx-auto max-w-2xl'>\n            There are Many Variations of Passages Of Lorem Ipsum Available\n          </p>\n        </div>\n\n        {/* Navigation and Filter */}\n        <div className='mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between'>\n          <Tabs\n            value={activeRegion}\n            onValueChange={value => setActiveRegion(value as (typeof regions)[number]['id'])}\n            className='w-full flex flex-col gap-4'\n          >\n            <div className='flex flex-wrap items-center justify-between gap-4'>\n              <TabsList className='bg-muted text-muted-foreground inline-flex !h-10 items-center justify-center rounded-md p-1'>\n                {regions.map(region => (\n                  <TabsTrigger\n                    key={region.id}\n                    value={region.id}\n                    className='!h-8.5 ring-offset-background focus-visible:ring-ring data-[state=active]:bg-background data-[state=active]:text-foreground relative inline-flex cursor-pointer items-center justify-center rounded-sm px-3 py-0.5 text-sm font-medium whitespace-nowrap transition-all focus-visible:ring-3 focus-visible:ring-offset-2 focus-visible:outline-hidden disabled:pointer-events-none disabled:opacity-50 data-[state=active]:shadow-xs'\n                  >\n                    {region.label}\n                  </TabsTrigger>\n                ))}\n              </TabsList>\n              <Button variant='outline' className=\"h-9 px-4 py-2 cursor-pointer gap-2\">\n                <SlidersHorizontal className='size-4' />\n                <span>Filter</span>\n              </Button>\n            </div>\n          </Tabs>\n        </div>\n\n        {/* Destinations Grid */}\n        <div className='grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3'>\n          {/* First Column */}\n          <div className='flex flex-col gap-6'>\n            <div className='group h-[300px]'>\n              <Card className='h-full overflow-hidden border-0 ring-0 p-0 shadow-xs transition-all hover:shadow-md'>\n                <CardContent className='relative h-full p-0'>\n                  <div className='size-full overflow-hidden'>\n                    <img\n                      src={destinations[0].image}\n                      alt={destinations[0].title}\n                      className='size-full object-cover opacity-80 transition-all duration-300 group-hover:opacity-100 group-hover:transition-opacity'\n                    />\n                    <div className='absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-transparent' />\n                    <CardBadges\n                      destination={destinations[0]}\n                      onFavorite={() => toggleFavorite(destinations[0].id)}\n                      isFavorite={favorites.includes(destinations[0].id)}\n                    />\n                  </div>\n                </CardContent>\n              </Card>\n            </div>\n            <div className='group h-[300px]'>\n              <Card className='h-full overflow-hidden border-0 ring-0 p-0 shadow-xs transition-all hover:shadow-md'>\n                <CardContent className='relative h-full p-0'>\n                  <div className='size-full overflow-hidden'>\n                    <img\n                      src={destinations[3].image}\n                      alt={destinations[3].title}\n                      className='size-full object-cover opacity-80 transition-all duration-300 group-hover:opacity-100 group-hover:transition-opacity'\n                    />\n                    <div className='absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-transparent' />\n                    <CardBadges\n                      destination={destinations[3]}\n                      onFavorite={() => toggleFavorite(destinations[3].id)}\n                      isFavorite={favorites.includes(destinations[3].id)}\n                    />\n                  </div>\n                </CardContent>\n              </Card>\n            </div>\n          </div>\n\n          {/* Second Column */}\n          <div className='flex flex-col gap-6'>\n            <div className='group h-[420px]'>\n              <Card className='h-full overflow-hidden border-0 ring-0 p-0 shadow-xs transition-all hover:shadow-md'>\n                <CardContent className='relative h-full p-0'>\n                  <div className='size-full overflow-hidden'>\n                    <img\n                      src={destinations[1].image}\n                      alt={destinations[1].title}\n                      className='size-full object-cover opacity-80 transition-all duration-300 group-hover:opacity-100 group-hover:transition-opacity'\n                    />\n                    <div className='absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-transparent' />\n                    <CardBadges\n                      destination={destinations[1]}\n                      onFavorite={() => toggleFavorite(destinations[1].id)}\n                      isFavorite={favorites.includes(destinations[1].id)}\n                    />\n                  </div>\n                </CardContent>\n              </Card>\n            </div>\n            <div className='group h-[180px]'>\n              <Card className='h-full overflow-hidden border-0 ring-0 p-0 shadow-xs transition-all hover:shadow-md'>\n                <CardContent className='relative h-full p-0'>\n                  <div className='size-full overflow-hidden'>\n                    <img\n                      src={destinations[4].image}\n                      alt={destinations[4].title}\n                      className='size-full object-cover opacity-80 transition-all duration-300 group-hover:opacity-100 group-hover:transition-opacity'\n                    />\n                    <div className='absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-transparent' />\n                    <CardBadges\n                      destination={destinations[4]}\n                      onFavorite={() => toggleFavorite(destinations[4].id)}\n                      isFavorite={favorites.includes(destinations[4].id)}\n                    />\n                  </div>\n                </CardContent>\n              </Card>\n            </div>\n          </div>\n\n          {/* Third Column */}\n          <div className='flex flex-col gap-6 sm:max-lg:col-span-2'>\n            <div className='group h-[300px]'>\n              <Card className='h-full overflow-hidden border-0 ring-0 p-0 shadow-xs transition-all hover:shadow-md'>\n                <CardContent className='relative h-full p-0'>\n                  <div className='size-full overflow-hidden'>\n                    <img\n                      src={destinations[2].image}\n                      alt={destinations[2].title}\n                      className='size-full object-cover opacity-80 transition-all duration-300 group-hover:opacity-100 group-hover:transition-opacity'\n                    />\n                    <div className='absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-transparent' />\n                    <CardBadges\n                      destination={destinations[2]}\n                      onFavorite={() => toggleFavorite(destinations[2].id)}\n                      isFavorite={favorites.includes(destinations[2].id)}\n                    />\n                  </div>\n                </CardContent>\n              </Card>\n            </div>\n            <div className='group h-[300px]'>\n              <Card className='h-full overflow-hidden border-0 ring-0 p-0 shadow-xs transition-all hover:shadow-md'>\n                <CardContent className='relative h-full p-0'>\n                  <div className='size-full overflow-hidden'>\n                    <img\n                      src={destinations[5].image}\n                      alt={destinations[5].title}\n                      className='size-full object-cover opacity-80 transition-all duration-300 group-hover:opacity-100 group-hover:transition-opacity'\n                    />\n                    <div className='absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-transparent' />\n                    <CardBadges\n                      destination={destinations[5]}\n                      onFavorite={() => toggleFavorite(destinations[5].id)}\n                      isFavorite={favorites.includes(destinations[5].id)}\n                    />\n                  </div>\n                </CardContent>\n              </Card>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  )\n}\n\n// Extracted card badges component for cleaner code\nfunction CardBadges({\n  destination,\n  onFavorite,\n  isFavorite,\n}: {\n  destination: (typeof destinations)[0]\n  onFavorite: () => void\n  isFavorite: boolean\n}) {\n  return (\n    <>\n      {/* Rating Badge */}\n      <Badge\n        className='h-auto rounded-md absolute start-4 top-4 flex items-center gap-1 px-3 py-1.5 backdrop-blur-xs'\n        variant='secondary'\n      >\n        <Star className='fill-foreground text-foreground size-3.5' />\n        <span className='text-foreground'>{destination.rating}.0</span>\n      </Badge>\n\n      {/* Favorite Button */}\n      <Button\n        variant='secondary'\n        size='icon'\n        onClick={e => {\n          e.stopPropagation()\n          onFavorite()\n        }}\n        className=\"absolute end-4 top-4 size-8 cursor-pointer rounded-full p-0 backdrop-blur-xs\"\n      >\n        <Heart className={`size-4 ${isFavorite ? 'fill-destructive text-destructive' : 'text-muted-foreground'}`} />\n      </Button>\n\n      {/* Location Badge */}\n      <div className='absolute start-4 bottom-4'>\n        <Badge className='h-auto rounded-md px-3 py-1.5 text-sm font-medium backdrop-blur-xs' variant='secondary'>\n          {destination.location}\n        </Badge>\n      </div>\n\n      {/* Price Badge */}\n      <div className='absolute end-4 bottom-4'>\n        <Badge className='h-auto rounded-md bg-primary/90 text-primary-foreground px-4 py-1.5 text-sm font-semibold backdrop-blur-xs'>\n          ${destination.price}\n        </Badge>\n      </div>\n    </>\n  )\n}\n", "type": "registry:block", "target": "src/components/bento-grid-1.tsx"}], "type": "registry:block"}
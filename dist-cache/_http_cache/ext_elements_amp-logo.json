ORS[mode];\n\n  if (variant === \"icon\") {\n    return (\n      <svg\n        role=\"img\"\n        viewBox=\"0 0 21 21\"\n        xmlns=\"http://www.w3.org/2000/svg\"\n        className={className}\n        fill=\"none\"\n      >\n        <title>Amp</title>\n        {ICON_PATHS.map((d, i) => (\n          <path key={i} d={d} fill={color} />\n        ))}\n      </svg>\n    );\n  }\n\n  if (variant === \"icon-color\") {\n    return (\n      <svg\n        role=\"img\"\n        viewBox=\"0 0 21 21\"\n        xmlns=\"http://www.w3.org/2000/svg\"\n        className={className}\n        fill=\"none\"\n      >\n        <title>Amp</title>\n        {ICON_PATHS.map((d, i) => (\n          <path key={i} d={d} fill={BRAND_COLOR} />\n        ))}\n      </svg>\n    );\n  }\n\n  return (\n    <svg\n      role=\"img\"\n      viewBox=\"0 0 21 21\"\n      xmlns=\"http://www.w3.org/2000/svg\"\n      className={className}\n      fill=\"none\"\n    >\n      <title>Amp</title>\n      {ICON_PATHS.map((d, i) => (\n        <path key={i} d={d} fill={BRAND_COLOR} />\n      ))}\n    </svg>\n  );\n}\n", "type": "registry:component"}], "meta": {"hasVariants": true, "variants": ["icon", "icon-color", "wordmark"], "variantTypes": {"base": ["icon", "icon-color", "wordmark"], "modes": ["dark", "light"]}}, "docs": "Amp coding agent logo with 3 base variants (icon mono, icon color with brand red, wordmark) and 2 modes (dark, light) = 6 total combinations. Brand color: #F34E3F.", "categories": ["AI", "logo", "brand"], "type": "registry:ui"}
{"$schema": "https://ui.shadcn.com/schema/registry-item.json", "name": "dashboard-stats", "title": "Dashboard Stats", "description": "A dashboard page with KPI stat cards, overview chart placeholder and recent sales list.", "dependencies": ["lucide-react"], "registryDependencies": ["https://nessra-ui.vercel.app/r/button.json", "https://nessra-ui.vercel.app/r/card.json", "https://nessra-ui.vercel.app/r/stat-card.json"], "files": [{"path": "registry/new-york/blocks/dashboard-stats.tsx", "content": "import { Activity, ArrowUpRight, CreditCard, Euro, Users } from \"lucide-react\"\n\nimport { Button } from \"@/components/ui/button\"\nimport {\n  Card,\n  CardAction,\n  CardContent,\n  CardDescription,\n  CardHeader,\n  CardTitle,\n} from \"@/components/ui/card\"\nimport { StatCard, StatCardGroup } from \"@/components/ui/stat-card\"\n\nexport function DashboardStats() {\n  return (\n    <div className=\"bg-background w-full space-y-6 p-6\">\n      {/* Stats Grid */}\n      <StatCardGroup columns={4}>\n        <StatCard\n          label=\"Total Revenue\"\n          value=\"45 231 \u20ac\"\n          trend={20}\n          trendLabel=\"from last month\"\n          icon={<Euro className=\"size-4\" />}\n        />\n        <StatCard\n          label=\"Subscriptions\"\n          value=\"+2 350\"\n          trend={180}\n          trendLabel=\"from last month\"\n          icon={<Users className=\"size-4\" />}\n        />\n        <StatCard\n          label=\"Sales\"\n          value=\"+12 234\"\n          trend={19}\n          trendLabel=\"from last month\"\n          icon={<CreditCard className=\"size-4\" />}\n        />\n        <StatCard\n          label=\"Active Now\"\n          value=\"573\"\n          trend={-3}\n          trendLabel=\"from last hour\"\n          icon={<Activity className=\"size-4\" />}\n        />\n      </StatCardGroup>\n\n      {/* Secondary Section */}\n      <div className=\"grid gap-6 md:grid-cols-2 lg:grid-cols-7\">\n        {/* Overview Card */}\n        <Card className=\"lg:col-span-4\">\n          <CardHeader>\n            <CardTitle>Overview</CardTitle>\n            <CardDescription>\n              Monthly revenue for the current year\n            </CardDescription>\n            <CardAction>\n              <Button variant=\"ghost\" size=\"sm\">\n                View all\n                <ArrowUpRight className=\"size-4\" />\n              </Button>\n            </CardAction>\n          </CardHeader>\n          <CardContent>\n            {/* Placeholder for chart */}\n            <div className=\"bg-muted/50 flex h-[300px] items-center justify-center rounded-lg border border-dashed\">\n              <p className=\"text-muted-foreground text-sm\">\n                Chart component here\n              </p>\n            </div>\n          </CardContent>\n        </Card>\n\n        {/* Recent Sales Card */}\n        <Card className=\"lg:col-span-3\">\n          <CardHeader>\n            <CardTitle>Recent Sales</CardTitle>\n            <CardDescription>265 sales this month</CardDescription>\n            <CardAction>\n              <Button variant=\"ghost\" size=\"sm\">\n                View all\n                <ArrowUpRight className=\"size-4\" />\n              </Button>\n            </CardAction>\n          </CardHeader>\n          <CardContent>\n            <div className=\"space-y-4\">\n              {recentSales.map((sale) => (\n                <div key={sale.email} className=\"flex items-center gap-4\">\n                  <div className=\"bg-muted flex size-10 items-center justify-center rounded-full font-medium\">\n                    {sale.name\n                      .split(\" \")\n                      .map((n) => n[0])\n                      .join(\"\")}\n                  </div>\n                  <div className=\"flex-1 space-y-1\">\n                    <p className=\"text-sm leading-none font-medium\">\n                      {sale.name}\n                    </p>\n                    <p className=\"text-muted-foreground text-xs\">\n                      {sale.email}\n                    </p>\n                  </div>\n                  <div className=\"font-medium\">{sale.amount}</div>\n                </div>\n              ))}\n            </div>\n          </CardContent>\n        </Card>\n      </div>\n    </div>\n  )\n}\n\nconst recentSales = [\n  { name: \"Olivia Martin\", email: \"olivia@example.com\", amount: \"+1 999 \u20ac\" },\n  { name: \"Jackson Lee\", email: \"jackson@example.com\", amount: \"+39 \u20ac\" },\n  { name: \"Isabella Nguyen\", email: \"isabella@example.com\", amount: \"+299 \u20ac\" },\n  { name: \"William Kim\", email: \"william@example.com\", amount: \"+99 \u20ac\" },\n  { name: \"Sofia Davis\", email: \"sofia@example.com\", amount: \"+39 \u20ac\" },\n]\n", "type": "registry:block"}], "type": "registry:block"}
{"$schema": "https://ui.shadcn.com/schema/registry-item.json", "name": "custom-demo-controls", "files": [{"path": "registry/default/internal/custom-demo-controls.tsx", "content": "import React from \"react\"\n\ninterface CustomDemoControlsProps extends React.PropsWithChildren {\n  trailingSlot?: React.ReactNode\n}\n\nexport function CustomDemoControls({\n  children,\n  trailingSlot,\n}: CustomDemoControlsProps) {\n  return (\n    <section className=\"relative overflow-hidden\">\n      <svg className=\"pointer-events-none absolute top-0 left-0 z-10 h-px w-full\">\n        <line\n          className=\"text-border\"\n          stroke=\"currentColor\"\n          strokeDasharray=\"8 4\"\n          strokeWidth=\"1\"\n          x1=\"0\"\n          x2=\"100%\"\n          y1=\"0\"\n          y2=\"0\"\n        />\n      </svg>\n\n      <svg className=\"pointer-events-none absolute bottom-0 left-0 z-10 h-px w-full\">\n        <line\n          className=\"text-border\"\n          stroke=\"currentColor\"\n          strokeDasharray=\"8 4\"\n          strokeWidth=\"1\"\n          x1=\"0\"\n          x2=\"100%\"\n          y1=\"0\"\n          y2=\"0\"\n        />\n      </svg>\n\n      <div className=\"px-8 py-4\">\n        <div className=\"flex items-start gap-4\">\n          <div className=\"min-w-0 flex-1\">{children}</div>\n          {trailingSlot ? (\n            <div className=\"relative z-20 ml-auto shrink-0\">{trailingSlot}</div>\n          ) : null}\n        </div>\n      </div>\n    </section>\n  )\n}\n", "type": "registry:ui"}], "type": "registry:ui"}